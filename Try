-- אלמנטים של ה-Control Panel (הפונקציות שלך)
local function setupControls()
    local list = Instance.new("UIListLayout", container)
    list.Padding = UDim.new(0, 10)
    list.HorizontalAlignment = Enum.HorizontalAlignment.Center

    local padding = Instance.new("UIPadding", container)
    padding.PaddingTop = UDim.new(0, 20)

    -- תיבת טקסט לשם שחקן
    local nameInput = Instance.new("TextBox")
    nameInput.Size = UDim2.new(0, 350, 0, 40)
    nameInput.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
    nameInput.TextColor3 = Color3.fromRGB(255, 255, 255)
    nameInput.PlaceholderText = "Enter Player Name..."
    nameInput.Text = ""
    nameInput.Font = Enum.Font.Gotham
    nameInput.Parent = container
    Instance.new("UICorner", nameInput)

    -- כפתור טלפורט
    local tpBtn = Instance.new("TextButton")
    tpBtn.Size = UDim2.new(0, 350, 0, 45)
    tpBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 75)
    tpBtn.Text = "Teleport Once"
    tpBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    tpBtn.Font = Enum.Font.GothamBold
    tpBtn.Parent = container
    Instance.new("UICorner", tpBtn)

    tpBtn.MouseButton1Click:Connect(function()
        local target = game.Players:FindFirstChild(nameInput.Text)
        if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
            player.Character.HumanoidRootPart.CFrame = target.Character.HumanoidRootPart.CFrame
        end
    end)

    -- טוגל טלפורט אינסופי
    local infTpBtn = Instance.new("TextButton")
    infTpBtn.Size = UDim2.new(0, 350, 0, 45)
    infTpBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 75)
    infTpBtn.Text = "Infinite Teleport: OFF"
    infTpBtn.TextColor3 = Color3.fromRGB(255, 100, 100)
    infTpBtn.Font = Enum.Font.GothamBold
    infTpBtn.Parent = container
    Instance.new("UICorner", infTpBtn)

    infTpBtn.MouseButton1Click:Connect(function()
        infiniteTeleport = not infiniteTeleport
        infTpBtn.Text = "Infinite Teleport: " .. (infiniteTeleport and "ON" or "OFF")
        infTpBtn.TextColor3 = infiniteTeleport and Color3.fromRGB(100, 255, 100) or Color3.fromRGB(255, 100, 100)
        
        spawn(function()
            while infiniteTeleport do
                local target = game.Players:FindFirstChild(nameInput.Text)
                if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
                    player.Character.HumanoidRootPart.CFrame = target.Character.HumanoidRootPart.CFrame
                end
                wait(0.1)
            end
        end)
    end)

    -- טוגל הגנה
    local protBtn = Instance.new("TextButton")
    protBtn.Size = UDim2.new(0, 350, 0, 45)
    protBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 75)
    protBtn.Text = "Protection: OFF"
    protBtn.TextColor3 = Color3.fromRGB(255, 100, 100)
    protBtn.Font = Enum.Font.GothamBold
    protBtn.Parent = container
    Instance.new("UICorner", protBtn)

    protBtn.MouseButton1Click:Connect(function()
        protectionEnabled = not protectionEnabled
        protBtn.Text = "Protection: " .. (protectionEnabled and "ON" or "OFF")
        protBtn.TextColor3 = protectionEnabled and Color3.fromRGB(100, 255, 100) or Color3.fromRGB(255, 100, 100)
        -- כאן תוכל להוסיף את הלוגיקה הספציפית של ההגנה שלך מהקוד המקורי
    end)
end

setupControls()

