local player = game.Players.LocalPlayer
local scriptParent = script.Parent

-- צבעים
local BG_COLOR = Color3.fromRGB(24, 24, 30)
local SIDEBAR_COLOR = Color3.fromRGB(31, 31, 39)
local ACCENT_COLOR = Color3.fromRGB(85, 255, 127)
local TEXT_PRIMARY = Color3.fromRGB(255, 255, 255)
local TEXT_SECONDARY = Color3.fromRGB(160, 160, 175)

-- פריים ראשי משודרג (הפאנל)
local panel = Instance.new("Frame")
panel.Size = UDim2.new(0, 680, 0, 420)
panel.Position = UDim2.new(0.5, -340, 0.5, -210)
panel.BackgroundColor3 = BG_COLOR
panel.BorderSizePixel = 0
panel.Parent = scriptParent.Parent -- בהנחה ש-scriptParent הוא ה-Frame של הפרופיל והם אחים

-- עיגול פינות לפאנל הראשי
local panelCorner = Instance.new("UICorner")
panelCorner.CornerRadius = UDim.new(0, 14)
panelCorner.Parent = panel

-- סרגל צד לכלים
local sidebar = Instance.new("Frame")
sidebar.Size = UDim2.new(0, 200, 1, 0)
sidebar.Position = UDim2.new(0, 0, 0, 0)
sidebar.BackgroundColor3 = SIDEBAR_COLOR
sidebar.BorderSizePixel = 0
sidebar.Parent = panel

local sidebarCorner = Instance.new("UICorner")
sidebarCorner.CornerRadius = UDim.new(0, 14)
sidebarCorner.Parent = sidebar

-- כותרת המשחק בסרגל הצד
local gameTitle = Instance.new("TextLabel")
gameTitle.Size = UDim2.new(1, -20, 0, 60)
gameTitle.Position = UDim2.new(0, 10, 0, 0)
gameTitle.BackgroundTransparency = 1
gameTitle.Text = "SFG | ROBLOX GAME"
gameTitle.TextColor3 = TEXT_PRIMARY
gameTitle.Font = Enum.Font.GothamBold
gameTitle.TextSize = 18
gameTitle.TextXAlignment = Enum.TextXAlignment.Left
gameTitle.Parent = sidebar

-- קטע תוכן ראשי
local content = Instance.new("Frame")
content.Size = UDim2.new(1, -210, 1, -20)
content.Position = UDim2.new(0, 210, 0, 10)
content.BackgroundTransparency = 1
content.Parent = panel

-- כפתור התחלה בולט
local startBtn = Instance.new("TextButton")
startBtn.Size = UDim2.new(0, 200, 0, 50)
startBtn.Position = UDim2.new(0.5, -100, 0.5, -25)
startBtn.BackgroundColor3 = ACCENT_COLOR
startBtn.Text = "START GAME"
startBtn.TextColor3 = BG_COLOR
startBtn.Font = Enum.Font.GothamBold
startBtn.TextSize = 20
startBtn.Parent = content

local startCorner = Instance.new("UICorner")
startCorner.CornerRadius = UDim.new(0, 10)
startCorner.Parent = startBtn

-- שורת פרופיל מובנית (משופרת מה-Frame המקורית שלך)
-- אנחנו מחליפים את הפאנל המקורי שלך בפאנל הזה
local profileBar = scriptParent
profileBar.Size = UDim2.new(0, 190, 0, 70)
profileBar.Position = UDim2.new(0, 5, 1, -75) -- מעט מעל התחתית
profileBar.BackgroundColor3 = Color3.fromRGB(45, 45, 55)
profileBar.BorderSizePixel = 0
profileBar.Parent = sidebar

-- עיגול פינות לפרופיל
local profileCorner = Instance.new("UICorner")
profileCorner.CornerRadius = UDim.new(0, 10)
profileCorner.Parent = profileBar

-- אחיות הפרופיל (מה שהיה לך ב-Explorer, עכשיו בתוך ה-Frame החדשה)
local avatarImage = profileBar:FindFirstChild("ImageLabel")
local textLabel = profileBar:FindFirstChild("TextLabel")

-- עדכון אווטר (מובנה לתוך העיצוב)
if avatarImage then
    avatarImage.Image = "rbxthumb://type=AvatarHeadShot&id=" .. player.UserId .. "&w=150&h=150"
    avatarImage.Position = UDim2.new(0, 10, 0, 10)
    avatarImage.Size = UDim2.new(0, 50, 0, 50)
    
    -- הוספת UICorner לאוואטר כדי שיהיה עגול
    local avatarCorner = Instance.new("UICorner")
    avatarCorner.CornerRadius = UDim.new(1, 0) -- עיגול מלא
    avatarCorner.Parent = avatarImage
end

-- עדכון טקסט
if textLabel then
    textLabel.Text = "Welcome Back, " .. player.DisplayName
    textLabel.Size = UDim2.new(1, -75, 1, 0)
    textLabel.Position = UDim2.new(0, 70, 0, 0)
    textLabel.TextColor3 = TEXT_PRIMARY
    textLabel.Font = Enum.Font.GothamMedium
    textLabel.TextWrapped = true -- אם השם ארוך
    textLabel.TextXAlignment = Enum.TextXAlignment.Left
    textLabel.BackgroundTransparency = 1
end

-- הוספת כפתור כיבוי בתוך שורת הפרופיל
local powerBtn = Instance.new("ImageButton")
powerBtn.Size = UDim2.new(0, 30, 0, 30)
powerBtn.Position = UDim2.new(1, -40, 0, 10)
powerBtn.BackgroundTransparency = 1
powerBtn.Image = "rbxassetid://15444511333" -- אייקון כוח דמה
powerBtn.ImageColor3 = Color3.fromRGB(255, 100, 100)
powerBtn.Parent = profileBar

-- סגירת הממשק
powerBtn.MouseButton1Click:Connect(function()
    panel:Destroy()
end)

-- ביטול הפריים המקורי שלך (עכשיו הוא הוחלף)
-- הערה: הקוד מניח ש-scriptParent הוא ה-Frame המקורי שלך מהתמונה.
-- אנחנו משנים אותו ל-Invisible כי יצרנו מחדש את הפרופיל כחלק מהסרגל.
if scriptParent.Parent:IsA("ScreenGui") then
    scriptParent.Parent.Enabled = false
    panel.Parent = scriptParent.Parent -- הפאנל החדש הולך ל-ScreenGui
end
