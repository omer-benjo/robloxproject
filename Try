-- יצירת כרטיס (Card)
local function createCard(titleText, descText, yPos)
    local card = Instance.new("Frame")
    card.Size = UDim2.new(1, -40, 0, 100)
    card.Position = UDim2.new(0, 20, 0, yPos)
    card.BackgroundColor3 = COLORS.Card
    card.Parent = content
    Instance.new("UICorner", card).CornerRadius = UDim.new(0, 10)
    
    local ct = Instance.new("TextLabel")
    ct.Size = UDim2.new(1, -20, 0, 30)
    ct.Position = UDim2.new(0, 15, 0, 10)
    ct.Text = titleText
    ct.TextColor3 = COLORS.TextPrimary
    ct.Font = Enum.Font.GothamBold
    ct.TextXAlignment = Enum.TextXAlignment.Left
    ct.BackgroundTransparency = 1
    ct.Parent = card
    
    local cd = Instance.new("TextLabel")
    cd.Size = UDim2.new(1, -20, 0, 20)
    cd.Position = UDim2.new(0, 15, 0, 35)
    cd.Text = descText
    cd.TextColor3 = COLORS.TextSecondary
    cd.Font = Enum.Font.Gotham
    cd.TextXAlignment = Enum.TextXAlignment.Left
    cd.BackgroundTransparency = 1
    cd.Parent = card
    
    return card
end

