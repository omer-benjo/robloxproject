		if game.JobId and game.JobId ~= "" then
			TeleportService:TeleportToPlaceInstance(game.PlaceId,game.JobId,player)
		else
			TeleportService:Teleport(game.PlaceId,player)
		end
	end)
end

-- SERVER FINDER
local function findServer()
	-- gather server ids from Roblox servers API (first few pages)
	local servers = {}
	local cursor = nil
	for page=1,6 do -- limit pages to avoid long loops
		local url = "https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?sortOrder=Asc&limit=100"
		if cursor then
			url = url .. "&cursor=" .. cursor
		end

		local ok, res = pcall(function()
			-- try game:HttpGet first (commonly available in exploit environments), otherwise use HttpService
			if (type(game.HttpGet) == "function") then
				return game:HttpGet(url)
			else
				return HttpService:GetAsync(url)
			end
		end)

		if not ok or not res then break end

		local decoded
		ok, decoded = pcall(function() return HttpService:JSONDecode(res) end)
		if not ok or not decoded or not decoded.data then break end

		for _,v in ipairs(decoded.data) do
			if v.playing < v.maxPlayers and tostring(v.id) ~= tostring(game.JobId) then
				table.insert(servers, tostring(v.id))
			end
		end

		if not decoded.nextPageCursor then break end
		cursor = decoded.nextPageCursor
	end

	if #servers == 0 then
		warn("No available servers found.")
		return
	end

	local target = servers[math.random(1, #servers)]

	-- If autoScript is ON, try to queue a script to run on teleport (supports common executors)
	if autoScript then
		-- script to run on the new server
		local queuedCode = [[
			local Players = game:GetService("Players")
			task.wait(3)
			-- try to become police (best-effort)
			pcall(function()
				game:GetService("ReplicatedStorage").Remotes.RequestStartJobSession:FireServer("Security","jobPad")
			end)
			task.wait(1)
			-- run police action on all players (best-effort)
			pcall(function()
				for _, pl in pairs(Players:GetPlayers()) do
					pcall(function()
						game:GetService("ReplicatedStorage").Remotes.RequestArrestCriminal:FireServer(pl)
					end)
				end
			end)
		]]

		local queued = false
		-- syn
		if type(syn) == "table" and type(syn.queue_on_teleport) == "function" then
			pcall(function() syn.queue_on_teleport(queuedCode) end)
			queued = true
		-- secure v3 / other executors
		elseif type(queue_on_teleport) == "function" then
			pcall(function() queue_on_teleport(queuedCode) end)
			queued = true
		elseif type(writefile) == "function" and type(loadstring) == "function" then
			-- some executors allow creating a file and queueing it; best-effort (not guaranteed)
			pcall(function()
				local fileName = "autorun_queued.lua"
				writefile(fileName, queuedCode)
				if type(syn) == "table" and type(syn.queue_on_teleport) == "function" then
					syn.queue_on_teleport("loadfile('"..fileName.."')()")
					queued = true
				end
			end)
		end

		if not queued then
			-- if we couldn't queue the code, inform via warning; also create a simple Notification in PlayerGui
			warn("AUTO SCRIPT: queue_on_teleport not available in this environment. Auto-run won't persist across teleport.")
			pcall(function()
				local pg = player:FindFirstChild("PlayerGui")
				if pg then
					local notice = Instance.new("TextLabel")
					notice.Size = UDim2.new(0,420,0,40)
					notice.Position = UDim2.new(.5,-210,.85,0)
					notice.BackgroundColor3 = Color3.fromRGB(40,40,40)
					notice.TextColor3 = Color3.new(1,1,1)
					notice.Font = Enum.Font.GothamBold
					notice.TextSize = 18
					notice.Text = "AUTO SCRIPT: not supported by executor. Turn on manually after teleport."
					notice.Parent = pg
					game:GetService("Debris"):AddItem(notice,6)
				end
			end)
		end
	end

	-- teleport to chosen server
	pcall(function()
		TeleportService:TeleportToPlaceInstance(game.PlaceId, target, player)
	end)
end

