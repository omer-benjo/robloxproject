-- RECONNECT
local function reconnect()

	pcall(function()

		if game.JobId and game.JobId ~= "" then

			TeleportService:TeleportToPlaceInstance(game.PlaceId,game.JobId,player)

		else

			TeleportService:Teleport(game.PlaceId,player)

		end

	end)

end


-- SERVER FINDER
local function findServer()

	local servers = {}
	local cursor = nil

	for page=1,6 do

		local url = "https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?sortOrder=Asc&limit=100"

		if cursor then
			url = url.."&cursor="..cursor
		end

		local success,res = pcall(function()
			return game:HttpGet(url)
		end)

		if not success then break end

		local data = HttpService:JSONDecode(res)

		for _,v in pairs(data.data) do

			if v.playing < v.maxPlayers and v.id ~= game.JobId then

				table.insert(servers,v.id)

			end

		end

		if not data.nextPageCursor then break end

		cursor = data.nextPageCursor

	end


	if #servers == 0 then
		warn("No servers found")
		return
	end

	local server = servers[math.random(1,#servers)]


	if autoScript then

		local code = 'loadstring(game:HttpGet("https://raw.githubusercontent.com/omer-benjo/robloxproject/main/Main2"))()'

		if syn and syn.queue_on_teleport then
			syn.queue_on_teleport(code)

		elseif queue_on_teleport then
			queue_on_teleport(code)
		end

	end


	TeleportService:TeleportToPlaceInstance(game.PlaceId, server, player)
end



