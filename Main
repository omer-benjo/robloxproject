-- BENJO SCRIPTS (Styled Version)

local Players = game:GetService("Players")
local TeleportService = game:GetService("TeleportService")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer
if not player then return end

local ACCENT = Color3.fromRGB(66,133,244)

-- RECONNECT
local function reconnect()
	pcall(function()
		if game.JobId and game.JobId ~= "" then
			TeleportService:TeleportToPlaceInstance(game.PlaceId,game.JobId,player)
		else
			TeleportService:Teleport(game.PlaceId,player)
		end
	end)
end

-- GUI
local gui = Instance.new("ScreenGui")
gui.ResetOnSpawn=false
gui.Parent=player:WaitForChild("PlayerGui")

local main=Instance.new("Frame",gui)
main.Size=UDim2.new(0,700,0,420)
main.Position=UDim2.new(.5,-350,.5,-210)
main.BackgroundColor3=Color3.fromRGB(30,30,35)
main.BorderSizePixel=0
Instance.new("UICorner",main)

-- HEADER
local header=Instance.new("Frame",main)
header.Size=UDim2.new(1,0,0,40)
header.BackgroundColor3=ACCENT

local title=Instance.new("TextLabel",header)
title.Size=UDim2.new(1,0,1,0)
title.BackgroundTransparency=1
title.Text="BENJO SCRIPTS"
title.Font=Enum.Font.GothamBold
title.TextSize=18
title.TextColor3=Color3.new(1,1,1)

local devButton = Instance.new("ImageButton")
devButton.Size = UDim2.new(0,28,0,28)
devButton.Position = UDim2.new(0,17,0,6)
devButton.BackgroundTransparency = 1
devButton.Image = "rbxassetid://86372372560089"
devButton.Parent = header

local minimize=Instance.new("TextButton",header)
minimize.Size=UDim2.new(0,40,0,25)
minimize.Position=UDim2.new(1,-45,0,7)
minimize.Text="-"
minimize.Font=Enum.Font.GothamBold
minimize.TextSize=20
minimize.BackgroundColor3=Color3.new(1,1,1)
minimize.TextColor3=ACCENT
Instance.new("UICorner",minimize)

-- TABS
local tabs=Instance.new("Frame",main)
tabs.Size=UDim2.new(0,180,1,-40)
tabs.Position=UDim2.new(0,0,0,40)
tabs.BackgroundColor3=Color3.fromRGB(22,22,26)

local list=Instance.new("UIListLayout",tabs)
list.Padding=UDim.new(0,12)
list.HorizontalAlignment=Enum.HorizontalAlignment.Center

local pad=Instance.new("UIPadding",tabs)
pad.PaddingTop=UDim.new(0,20)

local function makeTab(name,order)
	local b=Instance.new("TextButton")
	b.Size=UDim2.new(1,-20,0,44)
	b.BackgroundColor3=Color3.fromRGB(40,40,46)
	b.TextColor3=Color3.fromRGB(230,230,230)
	b.Text=name
	b.Font=Enum.Font.Gotham
	b.TextSize=16
	b.LayoutOrder=order
	b.Parent=tabs
	Instance.new("UICorner",b)
	return b
end

local tabHome=makeTab("Home",1)
local tabOutlaw=makeTab("Outlaw",2)
local tabPolice=makeTab("Police",3)
local tabReconnect=makeTab("Reconnect",4)

-- CONTENT
local content=Instance.new("Frame",main)
content.Size=UDim2.new(1,-180,1,-40)
content.Position=UDim2.new(0,180,0,40)
content.BackgroundColor3=Color3.fromRGB(45,45,50)

local function clear()
	for _,v in ipairs(content:GetChildren()) do
		v:Destroy()
	end
end

-- HOME
local function showHome()
	clear()

	local container=Instance.new("Frame",content)
	container.Size=UDim2.new(1,0,1,0)
	container.BackgroundTransparency=1

	local layout=Instance.new("UIListLayout",container)
	layout.HorizontalAlignment=Enum.HorizontalAlignment.Center
	layout.VerticalAlignment=Enum.VerticalAlignment.Center
	layout.Padding=UDim.new(0,10)

	local img=Players:GetUserThumbnailAsync(player.UserId,Enum.ThumbnailType.HeadShot,Enum.ThumbnailSize.Size180x180)

	local avatar=Instance.new("ImageLabel",container)
	avatar.Size=UDim2.new(0,120,0,120)
	avatar.BackgroundTransparency=1
	avatar.Image=img
	local c=Instance.new("UICorner",avatar)
	c.CornerRadius=UDim.new(1,0)

	local welcome=Instance.new("TextLabel",container)
	welcome.Size=UDim2.new(0,400,0,70)
	welcome.BackgroundTransparency=1
	welcome.Font=Enum.Font.GothamBold
	welcome.TextSize=28
	welcome.RichText=true
	welcome.TextColor3=Color3.new(1,1,1)
	welcome.TextXAlignment=Enum.TextXAlignment.Center
	welcome.Text="WELCOME BACK,\n<font color='rgb(255,0,0)'>"..string.upper(player.Name).."</font>"
end

-- OUTLAW
local function showOutlaw()
	clear()

	local label=Instance.new("TextLabel",content)
	label.Size=UDim2.new(1,0,0,60)
	label.Position=UDim2.new(0,0,0,40)
	label.BackgroundTransparency=1
	label.Text="Outlaw tools coming soon..."
	label.Font=Enum.Font.GothamBold
	label.TextSize=26
	label.TextColor3=Color3.new(1,1,1)
	label.TextXAlignment=Enum.TextXAlignment.Center
end

-- POLICE
local function showPolice()
	clear()

	local btn=Instance.new("TextButton",content)
	btn.Size=UDim2.new(0,250,0,60)
	btn.Position=UDim2.new(.5,-125,.4,0)
	btn.Text="Police Action"
	btn.Font=Enum.Font.GothamBold
	btn.TextSize=20
	btn.BackgroundColor3=Color3.fromRGB(70,130,255)
	btn.TextColor3=Color3.new(1,1,1)

	local corner=Instance.new("UICorner",btn)
	corner.CornerRadius=UDim.new(0,8)

	btn.MouseButton1Click:Connect(function()
		for _, player in pairs(Players:GetPlayers()) do
			local args = {
				[1] = player
			}
			game:GetService("ReplicatedStorage").Remotes.RequestArrestCriminal:FireServer(unpack(args))
		end
	end)
end

-- RECONNECT (FULL WINDOW STYLE)
local autoReconnect=false

local function showReconnect()
	clear()

	local container=Instance.new("Frame",content)
	container.Size=UDim2.new(1,0,1,0)
	container.BackgroundTransparency=1

	local layout=Instance.new("UIListLayout",container)
	layout.HorizontalAlignment=Enum.HorizontalAlignment.Center
	layout.VerticalAlignment=Enum.VerticalAlignment.Center
	layout.Padding=UDim.new(0,20)

	local reconnectBtn=Instance.new("TextButton",container)
	reconnectBtn.Size=UDim2.new(0.7,0,0,70)
	reconnectBtn.Text="RECONNECT"
	reconnectBtn.Font=Enum.Font.GothamBold
	reconnectBtn.TextSize=28
	reconnectBtn.BackgroundColor3=Color3.fromRGB(80,80,90)
	reconnectBtn.TextColor3=Color3.new(1,1,1)

	local corner=Instance.new("UICorner",reconnectBtn)
	corner.CornerRadius=UDim.new(0,10)

	reconnectBtn.MouseButton1Click:Connect(function()
		reconnect()
	end)

	local auto=Instance.new("TextButton",container)
	auto.Size=UDim2.new(0.7,0,0,50)
	auto.Text="AUTO RECONNECT: OFF"
	auto.Font=Enum.Font.GothamBold
	auto.TextSize=18
	auto.BackgroundColor3=Color3.fromRGB(66,133,244)
	auto.TextColor3=Color3.new(1,1,1)

	local c2=Instance.new("UICorner",auto)

	auto.MouseButton1Click:Connect(function()
		autoReconnect=not autoReconnect
		auto.Text=autoReconnect and "AUTO RECONNECT: ON" or "AUTO RECONNECT: OFF"
	end)
end

-- TAB CONNECTIONS
tabHome.MouseButton1Click:Connect(showHome)
tabOutlaw.MouseButton1Click:Connect(showOutlaw)
tabPolice.MouseButton1Click:Connect(showPolice)
tabReconnect.MouseButton1Click:Connect(showReconnect)

showHome()

-- DRAG
local dragging=false
local dragInput
local dragStart
local startPos

header.InputBegan:Connect(function(input)
	if input.UserInputType==Enum.UserInputType.MouseButton1 then
		dragging=true
		dragStart=input.Position
		startPos=main.Position

		input.Changed:Connect(function()
			if input.UserInputState==Enum.UserInputState.End then
				dragging=false
			end
		end)
	end
end)

header.InputChanged:Connect(function(input)
	if input.UserInputType==Enum.UserInputType.MouseMovement then
		dragInput=input
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if dragging and input==dragInput then
		local delta=input.Position-dragStart

		main.Position=UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset+delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset+delta.Y
		)
	end
end)

-- MINIMIZE
local minimized=false
local oldSize=main.Size

minimize.MouseButton1Click:Connect(function()
	if not minimized then

		oldSize=main.Size
		main.Size=UDim2.new(0,300,0,40)
		tabs.Visible=false
		content.Visible=false
		minimized=true
	else

		main.Size=oldSize
		tabs.Visible=true
		content.Visible=true
		minimized=false
	end
end)
